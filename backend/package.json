{
  "name": "seafood-safety-backend",
  "version": "1.0.0",
  "description": "Silver Bay Seafoods Safety Manager - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/initDatabase.js",
    "seed": "node scripts/seedData.js",
    "migrate": "node scripts/migrate.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:workflows": "jest tests/integration/workflows.test.js --verbose",
    "test:workflows:watch": "jest tests/integration/workflows.test.js --watch",
    "test:workflows:coverage": "jest tests/integration/workflows.test.js --coverage",
    "test:e2e": "jest tests/integration/workflows.test.js --coverage --verbose",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "keywords": [
    "safety",
    "seafood",
    "compliance",
    "jsa",
    "loto"
  ],
  "author": "Silver Bay Seafoods IT Department",
  "license": "PROPRIETARY",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/data/**"
    ]
  }
}
